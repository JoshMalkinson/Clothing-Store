---
import { categories } from '../lib/catalog';
import { withBase } from '../lib/url';

const collectionPhotos = [
  '/images/movement-lifestyle.webp',
  '/images/fabric-detail.webp',
  '/images/activewear-hero.webp',
  '/images/movement-lifestyle.webp',
];
---

<section class="collections section" id="collections">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Collections</p>
      <h2 class="section-title">Built for every part of an active day.</h2>
    </div>

    <ul class="collections__grid">
      {
        categories.map((item, i) => (
          <li class={`card card--${(i % 4) + 1}`}>
            <a class="card__link" href={withBase(`/shop#${item.slug}`)}>
              <div class="card__media" aria-hidden="true">
                <img class="card__photo" src={withBase(collectionPhotos[i % collectionPhotos.length])} alt="" loading="lazy" decoding="async" />
                <span class="card__index">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="card__body">
                <h3 class="card__title">{item.label}</h3>
                <p class="card__desc">{item.blurb}</p>
                <span class="card__cta">
                  Explore
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .collections {
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  .collections__grid {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .card {
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .card__media {
    position: relative;
    aspect-ratio: 5 / 4;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 1.1rem;
    overflow: hidden;
  }
  .card--1 .card__media {
    background: linear-gradient(150deg, var(--color-accent-soft), var(--color-bg));
  }
  .card--2 .card__media {
    background: linear-gradient(150deg, var(--color-surface-green), var(--color-bg));
  }
  .card--3 .card__media {
    background: linear-gradient(150deg, var(--color-surface), var(--color-accent-soft));
  }
  .card--4 .card__media {
    background: linear-gradient(150deg, var(--color-accent-soft), var(--color-surface-green));
  }
  .card__index {
    position: relative;
    z-index: 1;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    padding: 0.35rem 0.55rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-accent-deep);
    letter-spacing: 0.05em;
  }
  .card__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.88;
    transition: transform 0.45s var(--ease);
  }
  .card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(20, 34, 31, 0.18));
  }
  .card:hover .card__photo {
    transform: scale(1.04);
  }
  .card__body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .card__title {
    font-size: 1.35rem;
  }
  .card__desc {
    color: var(--color-text);
    font-size: 0.98rem;
  }
  .card__meta {
    margin-top: 0.25rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }
  .card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.92rem;
    font-weight: var(--weight-medium);
    color: var(--color-accent-deep);
  }
  .card__cta svg {
    width: 18px;
    height: 18px;
    transition: transform 0.25s var(--ease);
  }
  .card:hover .card__cta svg {
    transform: translateX(4px);
  }
  @media (min-width: 640px) {
    .collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .collections__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
