---
import { site } from '../site.config';
import { withBase } from '../lib/url';
const { hero } = site;
---

<section class="hero" id="top">
  <div class="hero__bg" aria-hidden="true">
    <span class="blob blob--1"></span>
    <span class="blob blob--2"></span>
    <span class="ring"></span>
  </div>

  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1 class="hero__title">{hero.title}</h1>
      <p class="lede hero__sub">{hero.subtitle}</p>

      <div class="hero__actions">
        <a class="btn btn--primary" href={withBase(hero.primaryHref)}>{hero.primaryLabel}</a>
        <a class="btn btn--ghost" href={withBase(hero.secondaryHref)}>{hero.secondaryLabel}</a>
      </div>

      <p class="hero__note">{hero.note}</p>
    </div>

    <div class="hero__visual">
      <div class="hero__panel">
        <span class="hero__panel-label">{hero.imageCaption}</span>
      </div>
      <div class="hero__chip">
        <strong>{hero.statValue}</strong>
        <span>{hero.statLabel}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 8vw, 7rem);
    background: linear-gradient(180deg, var(--color-surface-green), var(--color-bg) 70%);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.55;
  }
  .blob--1 {
    width: 460px;
    height: 460px;
    top: -160px;
    right: -120px;
    background: radial-gradient(circle at 30% 30%, var(--color-accent), transparent 70%);
  }
  .blob--2 {
    width: 320px;
    height: 320px;
    bottom: -140px;
    left: -90px;
    background: radial-gradient(circle at 50% 50%, var(--color-accent-soft), transparent 72%);
  }
  .ring {
    position: absolute;
    width: 280px;
    height: 280px;
    right: 8%;
    bottom: -90px;
    border: 1px solid var(--color-accent);
    border-radius: 50%;
    opacity: 0.4;
  }

  .hero__inner {
    position: relative;
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }
  .hero__title {
    font-size: clamp(2.6rem, 1.5rem + 5vw, 4.7rem);
    font-weight: var(--weight-medium);
    margin-top: 1.1rem;
    max-width: 16ch;
  }
  .hero__sub {
    margin-top: 1.5rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.25rem;
  }
  .hero__note {
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    letter-spacing: 0.01em;
  }

  .hero__visual {
    position: relative;
  }
  .hero__panel {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    background:
      radial-gradient(120% 90% at 75% 10%, var(--color-accent-soft), transparent 55%),
      linear-gradient(150deg, var(--color-surface-green), var(--color-bg));
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
  }
  .hero__panel-label {
    font-size: 0.82rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .hero__chip {
    position: absolute;
    left: -1rem;
    bottom: 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    max-width: 12rem;
  }
  .hero__chip strong {
    font-family: var(--font-display);
    font-size: 1.7rem;
    color: var(--color-accent-deep);
    line-height: 1;
  }
  .hero__chip span {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.35;
  }

  @media (min-width: 920px) {
    .hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
</style>
