---
import { withBase } from '../lib/url';
---

<section class="featured section" id="featured" aria-label="Featured pieces">
  <div class="container">
    <div class="featured__head">
      <div class="section-head">
        <p class="eyebrow">Featured pieces</p>
        <h2 class="section-title">A few favourites to start with.</h2>
      </div>
      <a class="btn btn--ghost featured__all" href={withBase('/shop')}>Shop all</a>
    </div>

    <p class="featured__status" data-featured-status>Loading featured pieces...</p>
    <ul class="featured__grid" data-featured-products></ul>
  </div>
</section>

<style>
  .featured__head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1.25rem;
  }
  .featured__status {
    margin-top: 2rem;
    color: var(--color-muted);
  }
  .featured__status:empty {
    display: none;
  }
  .featured__grid {
    display: grid;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .pcard {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
    height: 100%;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .pcard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .pcard__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background:
      radial-gradient(120% 90% at 80% 12%, var(--color-accent-soft), transparent 55%),
      linear-gradient(160deg, var(--color-surface-green), var(--color-bg));
  }
  .pcard__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pcard__tag,
  .pcard__cat {
    position: absolute;
    z-index: 1;
  }
  .pcard__tag {
    top: 0.85rem;
    left: 0.85rem;
    background: var(--color-bg);
    color: var(--color-accent-deep);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.7rem;
    font-size: 0.72rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pcard__cat {
    bottom: 0.85rem;
    left: 0.85rem;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent-deep);
    opacity: 0.85;
  }
  .pcard__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.25rem 1.25rem 1.4rem;
    flex: 1;
  }
  .pcard__name {
    font-size: 1.2rem;
  }
  .pcard__summary {
    font-size: 0.92rem;
    color: var(--color-text);
  }
  .pcard__price {
    margin-top: auto;
    padding-top: 1rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-heading);
  }
  @media (min-width: 640px) {
    .featured__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .featured__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  import {
    categoryLabel,
    formatPrice,
    hasSupabaseConfig,
    listProducts,
    productUrl,
    type RuntimeProduct,
  } from '../lib/runtime-products';

  const grid = document.querySelector<HTMLUListElement>('[data-featured-products]');
  const status = document.querySelector<HTMLElement>('[data-featured-status]');

  function setStatus(message = '') {
    if (status) status.textContent = message;
  }

  function card(product: RuntimeProduct) {
    const item = document.createElement('li');
    const link = document.createElement('a');
    link.className = 'pcard';
    link.href = productUrl(product.slug);

    const media = document.createElement('div');
    media.className = 'pcard__media';
    if (product.tag) {
      const tag = document.createElement('span');
      tag.className = 'pcard__tag';
      tag.textContent = product.tag;
      media.append(tag);
    }
    const cat = document.createElement('span');
    cat.className = 'pcard__cat';
    cat.textContent = categoryLabel(product.category);
    media.append(cat);
    if (product.image_url) {
      const image = document.createElement('img');
      image.className = 'pcard__img';
      image.src = product.image_url;
      image.alt = product.name;
      image.loading = 'lazy';
      media.append(image);
    }

    const body = document.createElement('div');
    body.className = 'pcard__body';
    const name = document.createElement('h3');
    name.className = 'pcard__name';
    name.textContent = product.name;
    const summary = document.createElement('p');
    summary.className = 'pcard__summary';
    summary.textContent = product.summary;
    const price = document.createElement('span');
    price.className = 'pcard__price';
    price.textContent = formatPrice(product.price);
    body.append(name, summary, price);
    link.append(media, body);
    item.append(link);
    return item;
  }

  async function init() {
    if (!hasSupabaseConfig()) {
      setStatus('Featured products will appear here after Supabase is configured.');
      return;
    }

    try {
      const products = (await listProducts({ featuredOnly: true })).slice(0, 4);
      if (!products.length) {
        setStatus('No featured products have been published yet.');
        return;
      }
      setStatus('');
      grid?.replaceChildren(...products.map(card));
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Unable to load featured products.');
    }
  }

  init();
</script>
