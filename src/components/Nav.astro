---
import { site } from '../site.config';
import { withBase } from '../lib/url';
---

<header class="nav">
  <div class="container nav__inner">
    <a class="brand" href={withBase('/')} aria-label={`${site.brand} home`}>
      <svg class="brand__mark" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2.5C12 2.5 4 6.5 4 13a8 8 0 0 0 16 0c0-6.5-8-10.5-8-10.5Z" fill="var(--color-accent)" />
        <path d="M12 21.5V8.5" stroke="var(--color-accent-deep)" stroke-width="1.5" stroke-linecap="round" />
        <path d="M12 13.5l3-2.2M12 16.2l-3-2.2" stroke="var(--color-accent-deep)" stroke-width="1.3" stroke-linecap="round" />
      </svg>
      <span class="brand__name">{site.brand}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {site.nav.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
    </nav>

    <a class="btn btn--primary nav__cta" href={withBase(site.ctaHref)}>{site.ctaLabel}</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    height: 76px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .brand__name {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: 1.4rem;
    letter-spacing: 0.005em;
    color: var(--color-heading);
  }
  .nav__links {
    display: none;
    gap: clamp(1.5rem, 3vw, 2.75rem);
  }
  .nav__links a {
    position: relative;
    font-size: 0.96rem;
    color: var(--color-text-strong);
    transition: color 0.2s var(--ease);
  }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 1.5px;
    background: var(--color-accent-strong);
    transition: width 0.25s var(--ease);
  }
  .nav__links a:hover {
    color: var(--color-accent-deep);
  }
  .nav__links a:hover::after {
    width: 100%;
  }
  .nav__cta {
    display: none;
  }
  @media (min-width: 900px) {
    .nav__links {
      display: inline-flex;
    }
    .nav__cta {
      display: inline-flex;
    }
  }
</style>
