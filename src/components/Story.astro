---
import { site } from '../site.config';
import { withBase } from '../lib/url';
const { approach } = site;
---

<section class="story section" id="approach">
  <div class="container story__inner">
    <div class="story__copy">
      <p class="eyebrow">{approach.eyebrow}</p>
      <h2 class="section-title">{approach.title}</h2>
      {approach.paragraphs.map((p) => <p class="story__p">{p}</p>)}

      <dl class="story__stats">
        {
          approach.stats.map((stat) => (
            <div class="stat">
              <dt class="stat__value">{stat.value}</dt>
              <dd class="stat__label">{stat.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="story__visual" aria-hidden="true">
      <div class="story__panel">
        <img src={withBase('/images/fabric-detail.webp')} alt="" loading="lazy" decoding="async" />
      </div>
      <span class="story__dot"></span>
    </div>
  </div>
</section>

<style>
  .story__inner {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }
  .story__p {
    margin-top: 1.25rem;
    color: var(--color-text);
    max-width: 56ch;
  }
  .story__stats {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
    width: fit-content;
  }
  .stat__value {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.3rem);
    color: var(--color-accent-deep);
    line-height: 1;
  }
  .stat__label {
    margin-top: 0.45rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    max-width: 16ch;
  }

  .story__visual {
    position: relative;
    order: -1;
  }
  .story__panel {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
    background:
      radial-gradient(110% 110% at 20% 15%, var(--color-accent-soft), transparent 55%),
      linear-gradient(160deg, var(--color-surface-green), var(--color-bg));
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    overflow: hidden;
    position: relative;
  }
  .story__panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(36, 58, 54, 0.18));
    pointer-events: none;
  }
  .story__panel img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .story__dot {
    position: absolute;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    right: -22px;
    top: -22px;
    background: var(--color-accent);
    opacity: 0.5;
    filter: blur(2px);
  }

  @media (min-width: 920px) {
    .story__inner {
      grid-template-columns: 1fr 1fr;
    }
    .story__visual {
      order: 0;
    }
  }
</style>
