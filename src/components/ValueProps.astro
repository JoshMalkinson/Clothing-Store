---
import { site } from '../site.config';
const { valueProps } = site;
---

<section class="vp section" aria-label="Why families choose us">
  <div class="container">
    <ul class="vp__grid">
      {
        valueProps.map((item) => (
          <li class="vp__item">
            <span class="vp__icon" aria-hidden="true">
              {item.icon === 'motion' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8h9a3 3 0 1 0-3-3" />
                  <path d="M3 12h13a3 3 0 1 1-3 3" />
                  <path d="M3 16h7" />
                </svg>
              )}
              {item.icon === 'durable' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3l7 3v5c0 4.6-3.1 7.7-7 9-3.9-1.3-7-4.4-7-9V6l7-3z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              )}
              {item.icon === 'care' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 21C12 21 4 15.5 4 9.8A4.3 4.3 0 0 1 12 7a4.3 4.3 0 0 1 8 2.8C20 15.5 12 21 12 21Z" />
                </svg>
              )}
            </span>
            <h3 class="vp__title">{item.title}</h3>
            <p class="vp__desc">{item.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .vp {
    border-top: 1px solid var(--color-line);
  }
  .vp__grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  .vp__item {
    max-width: 38ch;
  }
  .vp__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: var(--color-surface-green);
    color: var(--color-accent-strong);
    margin-bottom: 1.4rem;
  }
  .vp__icon svg {
    width: 26px;
    height: 26px;
  }
  .vp__title {
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
  }
  .vp__desc {
    color: var(--color-text);
  }
  @media (min-width: 760px) {
    .vp__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
