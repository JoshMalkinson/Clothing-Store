---
import Base from '../../layouts/Base.astro';
import { runtimeCategories } from '../../lib/runtime-products';
import { site } from '../../site.config';
---

<Base
  title={`Shop — ${site.brand}`}
  description={`Browse the full ${site.brand} range of activewear for kids and teenagers, ages 4 to 16.`}
>
  <main>
    <section class="shop-head">
      <div class="container">
        <p class="eyebrow">Shop</p>
        <h1 class="shop-head__title">The full range.</h1>
        <p class="lede" data-count-copy>
          Considered activewear for ages 4&ndash;16, built to move and made to last.
        </p>
      </div>
    </section>

    <section class="section shop">
      <div class="container">
        <div class="filters" role="group" aria-label="Filter by collection">
          <button class="chip" type="button" data-filter="all" aria-pressed="true">All</button>
          {
            runtimeCategories.map((c) => (
              <button class="chip" type="button" data-filter={c.slug} aria-pressed="false">
                {c.label}
              </button>
            ))
          }
        </div>

        <p class="shop__status" data-status>Loading products...</p>
        <ul class="shop__grid" data-products></ul>
        <p class="shop__empty" data-empty hidden>No pieces in this collection just yet.</p>
      </div>
    </section>
  </main>
</Base>

<style>
  .shop-head {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    background: linear-gradient(180deg, var(--color-surface-green), var(--color-bg));
    border-bottom: 1px solid var(--color-line);
  }
  .shop-head__title {
    font-size: clamp(2.4rem, 1.5rem + 3.5vw, 3.6rem);
    margin: 0.8rem 0 1rem;
  }
  .shop {
    padding-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .chip {
    padding: 0.6rem 1.15rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-line);
    background: var(--color-bg);
    color: var(--color-text-strong);
    font-size: 0.92rem;
    cursor: pointer;
    transition: background-color 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
  }
  .chip[aria-pressed='true'] {
    background: var(--color-accent-strong);
    border-color: var(--color-accent-strong);
    color: var(--color-on-accent);
  }
  .shop__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .shop__item[hidden] {
    display: none;
  }
  .shop__status,
  .shop__empty {
    color: var(--color-muted);
  }
  .shop__status {
    margin-bottom: 1.5rem;
  }
  .shop__status:empty {
    display: none;
  }
  .shop__empty {
    margin-top: 2rem;
  }
  .pcard {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
    height: 100%;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .pcard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .pcard__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background:
      radial-gradient(120% 90% at 80% 12%, var(--color-accent-soft), transparent 55%),
      linear-gradient(160deg, var(--color-surface-green), var(--color-bg));
  }
  .pcard[data-category='on-the-field'] .pcard__media {
    background:
      radial-gradient(120% 90% at 80% 12%, var(--color-accent-soft), transparent 55%),
      linear-gradient(160deg, var(--color-surface), var(--color-bg));
  }
  .pcard[data-category='cooler-days'] .pcard__media {
    background: linear-gradient(160deg, var(--color-accent-soft), var(--color-surface));
  }
  .pcard[data-category='rest-recover'] .pcard__media {
    background: linear-gradient(160deg, var(--color-surface-green), var(--color-accent-soft));
  }
  .pcard__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pcard__tag {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 1;
    background: var(--color-bg);
    color: var(--color-accent-deep);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.7rem;
    font-size: 0.72rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pcard__cat {
    position: absolute;
    bottom: 0.85rem;
    left: 0.85rem;
    z-index: 1;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent-deep);
    opacity: 0.85;
  }
  .pcard__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.25rem 1.25rem 1.4rem;
    flex: 1;
  }
  .pcard__name {
    font-size: 1.2rem;
  }
  .pcard__summary {
    font-size: 0.92rem;
    color: var(--color-text);
  }
  .pcard__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
  }
  .pcard__price {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-heading);
  }
  .pcard__swatches {
    display: inline-flex;
    gap: 0.35rem;
  }
  .swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--swatch);
    box-shadow: inset 0 0 0 1px rgba(24, 29, 25, 0.12);
  }
</style>

<script>
  import {
    categoryLabel,
    colorHex,
    formatPrice,
    hasSupabaseConfig,
    listProducts,
    productUrl,
    type RuntimeProduct,
  } from '../../lib/runtime-products';

  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
  const grid = document.querySelector<HTMLUListElement>('[data-products]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const status = document.querySelector<HTMLElement>('[data-status]');
  const countCopy = document.querySelector<HTMLElement>('[data-count-copy]');
  let products: RuntimeProduct[] = [];
  let activeFilter = 'all';

  function setStatus(message = '') {
    if (status) status.textContent = message;
  }

  function renderProduct(product: RuntimeProduct) {
    const item = document.createElement('li');
    item.className = 'shop__item';
    item.dataset.category = product.category;

    const card = document.createElement('a');
    card.className = 'pcard';
    card.href = productUrl(product.slug);
    card.dataset.category = product.category;

    const media = document.createElement('div');
    media.className = 'pcard__media';

    if (product.tag) {
      const tag = document.createElement('span');
      tag.className = 'pcard__tag';
      tag.textContent = product.tag;
      media.append(tag);
    }

    const category = document.createElement('span');
    category.className = 'pcard__cat';
    category.textContent = categoryLabel(product.category);
    media.append(category);

    if (product.image_url) {
      const image = document.createElement('img');
      image.className = 'pcard__img';
      image.src = product.image_url;
      image.alt = product.name;
      image.loading = 'lazy';
      media.append(image);
    }

    const body = document.createElement('div');
    body.className = 'pcard__body';

    const name = document.createElement('h3');
    name.className = 'pcard__name';
    name.textContent = product.name;

    const summary = document.createElement('p');
    summary.className = 'pcard__summary';
    summary.textContent = product.summary;

    const foot = document.createElement('div');
    foot.className = 'pcard__foot';

    const price = document.createElement('span');
    price.className = 'pcard__price';
    price.textContent = formatPrice(product.price);

    const swatches = document.createElement('span');
    swatches.className = 'pcard__swatches';
    swatches.setAttribute('aria-label', `Colours: ${product.colors.join(', ')}`);
    for (const color of product.colors) {
      const swatch = document.createElement('span');
      swatch.className = 'swatch';
      swatch.title = color;
      swatch.style.setProperty('--swatch', colorHex(color));
      swatches.append(swatch);
    }

    foot.append(price, swatches);
    body.append(name, summary, foot);
    card.append(media, body);
    item.append(card);
    return item;
  }

  function apply(filter: string) {
    activeFilter = filter;
    let visible = 0;
    for (const item of Array.from(document.querySelectorAll<HTMLElement>('.shop__item'))) {
      const show = filter === 'all' || item.dataset.category === filter;
      item.toggleAttribute('hidden', !show);
      if (show) visible += 1;
    }
    for (const chip of chips) {
      chip.setAttribute('aria-pressed', String(chip.dataset.filter === filter));
    }
    if (empty) empty.toggleAttribute('hidden', visible !== 0 || products.length === 0);
  }

  function render() {
    if (!grid) return;
    grid.replaceChildren(...products.map(renderProduct));
    if (countCopy) {
      countCopy.textContent = `Considered activewear for ages 4-16, built to move and made to last. ${products.length} pieces across four collections.`;
    }
    apply(activeFilter);
  }

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter ?? 'all';
      apply(filter);
      const base = import.meta.env.BASE_URL;
      history.replaceState(null, '', filter === 'all' ? `${base}shop` : `${base}shop#${filter}`);
    });
  }

  async function init() {
    const initial = location.hash.replace('#', '');
    const isValid = chips.some((chip) => chip.dataset.filter === initial);
    activeFilter = isValid ? initial : 'all';

    if (!hasSupabaseConfig()) {
      setStatus('Supabase is not configured yet. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY to enable the live catalogue.');
      return;
    }

    try {
      products = await listProducts();
      setStatus(products.length ? '' : 'No products have been published yet.');
      render();
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Unable to load products right now.');
    }
  }

  init();
</script>
