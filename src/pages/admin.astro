---
import Base from '../layouts/Base.astro';
import { runtimeCategories } from '../lib/runtime-products';
import { site } from '../site.config';
---

<Base title={`Admin — ${site.brand}`} description={`Product administration for ${site.brand}.`}>
  <main class="admin">
    <div class="container admin__inner">
      <section class="admin__head">
        <p class="eyebrow">Admin</p>
        <h1 class="admin__title">Product manager</h1>
        <p class="admin__lede">Create live catalogue products without rebuilding the site.</p>
      </section>

      <p class="admin__status" data-global-status></p>

      <section class="admin__panel admin__panel--notice" data-preview-panel hidden>
        <h2>Preview mode</h2>
        <p>
          Supabase is not connected yet, so products created here are saved only in this
          browser for testing the form. Once Supabase is configured, sign in to publish
          products live.
        </p>
      </section>

      <section class="admin__panel" data-login-panel>
        <h2>Sign in</h2>
        <form class="admin__form" data-login-form>
          <label>
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
          <label>
            <span>Password</span>
            <input type="password" name="password" autocomplete="current-password" required />
          </label>
          <button class="btn btn--primary" type="submit">Sign in</button>
        </form>
      </section>

      <section class="admin__panel" data-editor-panel hidden>
        <div class="admin__bar">
          <div>
            <h2 data-form-title>Add product</h2>
            <p data-session-label></p>
          </div>
          <button class="btn btn--ghost" type="button" data-sign-out>Sign out</button>
        </div>

        <form class="admin__form admin__form--grid" data-product-form>
          <label>
            <span>Name</span>
            <input type="text" name="name" required />
          </label>

          <label>
            <span>Slug</span>
            <input type="text" name="slug" required />
          </label>

          <label>
            <span>Category</span>
            <select name="category" required>
              {
                runtimeCategories.map((category) => (
                  <option value={category.slug}>{category.label}</option>
                ))
              }
            </select>
          </label>

          <label>
            <span>Price (ZAR)</span>
            <input type="number" name="price" min="0" step="1" required />
          </label>

          <label>
            <span>Sizes</span>
            <input type="text" name="sizes" placeholder="4-5y, 6-7y, 8-9y" required />
          </label>

          <label>
            <span>Colours</span>
            <input type="text" name="colors" placeholder="Sage, Chalk, Slate" required />
          </label>

          <label>
            <span>Tag</span>
            <input type="text" name="tag" placeholder="New, Bestseller" />
          </label>

          <label>
            <span>Sort order</span>
            <input type="number" name="sort_order" min="0" step="1" value="99" required />
          </label>

          <label class="admin__wide">
            <span>Summary</span>
            <input type="text" name="summary" maxlength="180" required />
          </label>

          <label class="admin__wide">
            <span>Description</span>
            <textarea name="description" rows="6" required></textarea>
          </label>

          <label class="admin__wide">
            <span>Product image</span>
            <input type="file" name="image" accept="image/*" />
          </label>

          <div class="admin__checks admin__wide">
            <label>
              <input type="checkbox" name="featured" />
              <span>Featured product</span>
            </label>
            <label>
              <input type="checkbox" name="published" checked />
              <span>Published</span>
            </label>
          </div>

          <div class="admin__actions admin__wide">
            <button class="btn btn--primary" type="submit" data-submit-product>Create product</button>
            <button class="btn btn--ghost" type="button" data-cancel-edit hidden>Cancel edit</button>
            <p data-form-status></p>
          </div>
        </form>

        <div class="admin__preview-list admin__wide" data-preview-list hidden>
          <h3>Local preview products</h3>
          <ul data-preview-products></ul>
        </div>
      </section>

      <section class="admin__panel" data-products-panel hidden>
        <div class="admin__bar">
          <div>
            <h2>Current products</h2>
            <p data-products-status>Loading products...</p>
          </div>
          <button class="btn btn--ghost" type="button" data-refresh-products>Refresh</button>
        </div>

        <div class="admin__table-wrap">
          <table class="admin__table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Slug</th>
                <th>Category</th>
                <th>Price</th>
                <th>Featured</th>
                <th>Published</th>
                <th>Order</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody data-products-table></tbody>
          </table>
        </div>
      </section>
    </div>
  </main>
</Base>

<style>
  .admin {
    min-height: 70vh;
    padding-block: clamp(3rem, 7vw, 5rem) clamp(4rem, 8vw, 7rem);
    background: linear-gradient(180deg, var(--color-surface-green), var(--color-bg) 18rem);
  }
  .admin__inner {
    max-width: 1320px;
  }
  .admin__title {
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.4rem);
    margin-top: 0.8rem;
  }
  .admin__lede {
    margin-top: 1rem;
    color: var(--color-text);
  }
  .admin__status {
    margin-block: 1.5rem;
    color: var(--color-muted);
  }
  .admin__status:empty {
    display: none;
  }
  .admin__panel {
    margin-top: 2rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-bg);
    box-shadow: var(--shadow-md);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }
  .admin__panel h2 {
    font-size: 1.6rem;
    margin-bottom: 1.25rem;
  }
  .admin__panel--notice {
    box-shadow: var(--shadow-sm);
    background: var(--color-surface-green);
  }
  .admin__panel--notice p {
    color: var(--color-text-strong);
  }
  .admin__bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .admin__bar p,
  .admin__actions p {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .admin__form {
    display: grid;
    gap: 1rem;
  }
  .admin__form--grid {
    grid-template-columns: 1fr;
  }
  .admin__wide {
    grid-column: 1 / -1;
  }
  .admin__form label {
    display: grid;
    gap: 0.4rem;
    color: var(--color-text-strong);
    font-size: 0.92rem;
  }
  .admin__form input,
  .admin__form select,
  .admin__form textarea {
    width: 100%;
    border: 2px solid color-mix(in srgb, var(--color-muted) 62%, var(--color-line));
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    padding: 0.8rem 0.9rem;
    outline: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
    transition:
      border-color 0.2s var(--ease),
      box-shadow 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .admin__form textarea {
    resize: vertical;
  }
  .admin__form input:hover,
  .admin__form select:hover,
  .admin__form textarea:hover {
    border-color: color-mix(in srgb, var(--color-accent-deep) 38%, var(--color-line));
  }
  .admin__form input:focus-visible,
  .admin__form select:focus-visible,
  .admin__form textarea:focus-visible {
    border-color: var(--color-accent-deep);
    background: #fff;
    box-shadow:
      0 0 0 4px var(--color-accent-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }
  .admin__checks {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .admin__checks label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .admin__checks input {
    width: auto;
  }
  .admin__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .admin__preview-list {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
  }
  .admin__preview-list h3 {
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
  }
  .admin__preview-list li {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem 1rem;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text-strong);
  }
  .admin__preview-list span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .admin__table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }
  .admin__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 1180px;
  }
  :global(.admin__table th),
  :global(.admin__table td) {
    padding: 0.95rem 0.9rem;
    border-bottom: 1px solid var(--color-line);
    border-right: 1px solid var(--color-line);
    text-align: left;
    vertical-align: top;
  }
  :global(.admin__table th:last-child),
  :global(.admin__table td:last-child) {
    border-right: 0;
  }
  :global(.admin__table tbody tr:last-child td) {
    border-bottom: 0;
  }
  :global(.admin__table tbody tr:nth-child(even)) {
    background: var(--color-bg-soft);
  }
  :global(.admin__table tbody tr:hover) {
    background: var(--color-surface-green);
  }
  :global(.admin__table th) {
    background: var(--color-surface);
    font-size: 0.74rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  :global(.admin__table td) {
    font-size: 0.92rem;
    color: var(--color-text-strong);
  }
  :global(.admin__table th:last-child),
  :global(.admin__table td:last-child) {
    width: 21rem;
  }
  :global(.admin__slug) {
    color: var(--color-muted);
    font-size: 0.84rem;
    word-break: break-word;
  }
  :global(.admin__pill) {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.55rem;
    font-size: 0.78rem;
    color: var(--color-text-strong);
    background: var(--color-bg-soft);
  }
  :global(.admin__table a) {
    color: var(--color-accent-deep);
    font-weight: var(--weight-medium);
  }
  :global(.admin__row-actions) {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.9rem;
    min-width: 20rem;
    white-space: nowrap;
  }
  :global(.admin__action) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
    min-width: 4.75rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.78rem;
    font-weight: var(--weight-semibold);
    cursor: pointer;
    transition: transform 0.2s var(--ease), background-color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  :global(.admin__action:hover) {
    background: var(--color-accent-deep);
    transform: translateY(-1px);
  }
  :global(.admin__action--edit) {
    background: #2b7fc1;
  }
  :global(.admin__action--edit:hover) {
    background: #1e6096;
  }
  :global(.admin__action--danger) {
    background: #c55252;
  }
  :global(.admin__action--danger:hover) {
    background: #9f3838;
  }
  @media (min-width: 720px) {
    .admin__form--grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<script>
  import {
    createProduct,
    deleteProduct,
    hasSupabaseConfig,
    listAdminProducts,
    signInWithPassword,
    slugify,
    updateProduct,
    uploadProductImage,
    type CategorySlug,
    type RuntimeProduct,
    type SupabaseSession,
    categoryLabel,
    formatPrice,
    productUrl,
  } from '../lib/runtime-products';

  const sessionKey = 'action-bodywear-admin-session';
  const previewKey = 'action-bodywear-preview-products';
  const loginPanel = document.querySelector<HTMLElement>('[data-login-panel]');
  const editorPanel = document.querySelector<HTMLElement>('[data-editor-panel]');
  const productsPanel = document.querySelector<HTMLElement>('[data-products-panel]');
  const productsStatus = document.querySelector<HTMLElement>('[data-products-status]');
  const productsTable = document.querySelector<HTMLTableSectionElement>('[data-products-table]');
  const refreshProducts = document.querySelector<HTMLButtonElement>('[data-refresh-products]');
  const previewPanel = document.querySelector<HTMLElement>('[data-preview-panel]');
  const previewList = document.querySelector<HTMLElement>('[data-preview-list]');
  const previewProducts = document.querySelector<HTMLUListElement>('[data-preview-products]');
  const loginForm = document.querySelector<HTMLFormElement>('[data-login-form]');
  const productForm = document.querySelector<HTMLFormElement>('[data-product-form]');
  const globalStatus = document.querySelector<HTMLElement>('[data-global-status]');
  const formStatus = document.querySelector<HTMLElement>('[data-form-status]');
  const formTitle = document.querySelector<HTMLElement>('[data-form-title]');
  const submitProduct = document.querySelector<HTMLButtonElement>('[data-submit-product]');
  const cancelEdit = document.querySelector<HTMLButtonElement>('[data-cancel-edit]');
  const sessionLabel = document.querySelector<HTMLElement>('[data-session-label]');
  const signOut = document.querySelector<HTMLButtonElement>('[data-sign-out]');
  const nameInput = productForm?.elements.namedItem('name') as HTMLInputElement | null;
  const slugInput = productForm?.elements.namedItem('slug') as HTMLInputElement | null;
  let slugWasEdited = false;
  let session: SupabaseSession | null = loadSession();
  let editingProduct: RuntimeProduct | null = null;
  let adminProducts: RuntimeProduct[] = [];

  function setText(el: HTMLElement | null, message = '') {
    if (el) el.textContent = message;
  }

  function loadSession(): SupabaseSession | null {
    const raw = localStorage.getItem(sessionKey);
    if (!raw) return null;
    try {
      const parsed = JSON.parse(raw) as SupabaseSession;
      if (!parsed.access_token) return null;
      return parsed;
    } catch {
      return null;
    }
  }

  function saveSession(value: SupabaseSession | null) {
    session = value;
    if (value) localStorage.setItem(sessionKey, JSON.stringify(value));
    else localStorage.removeItem(sessionKey);
    renderAuthState();
  }

  function renderAuthState() {
    const ready = hasSupabaseConfig();
    if (!ready) {
      setText(globalStatus, 'Local preview mode is active.');
    } else if (!session) {
      setText(globalStatus, 'Sign in to publish products live.');
    } else {
      setText(globalStatus, '');
    }

    previewPanel?.toggleAttribute('hidden', ready);
    loginPanel?.toggleAttribute('hidden', Boolean(session) || !ready);
    editorPanel?.toggleAttribute('hidden', ready ? !session : false);
    productsPanel?.toggleAttribute('hidden', ready ? !session : false);
    setText(
      sessionLabel,
      ready
        ? session?.user?.email
          ? `Signed in as ${session.user.email}`
          : ''
        : 'Preview only. Connect Supabase to publish live.',
    );
    renderPreviewProducts();
    if (ready && session) void loadProductsTable();
    if (!ready) renderPreviewProductsTable();
  }

  function csv(value: FormDataEntryValue | null): string[] {
    return String(value ?? '')
      .split(',')
      .map((item) => item.trim())
      .filter(Boolean);
  }

  function field<T extends HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(name: string): T | null {
    return (productForm?.elements.namedItem(name) as T | null) ?? null;
  }

  function setChecked(name: string, checked: boolean) {
    const input = field<HTMLInputElement>(name);
    if (input) input.checked = checked;
  }

  function setFormMode(product: RuntimeProduct | null) {
    editingProduct = product;
    setText(formTitle, product ? `Edit ${product.name}` : 'Add product');
    if (submitProduct) submitProduct.textContent = product ? 'Save changes' : 'Create product';
    cancelEdit?.toggleAttribute('hidden', !product);
    setText(formStatus, product ? 'Editing an existing product.' : '');
  }

  function resetProductForm(message = '') {
    productForm?.reset();
    slugWasEdited = false;
    const sortOrder = field<HTMLInputElement>('sort_order');
    if (sortOrder) sortOrder.value = '99';
    setChecked('published', true);
    setFormMode(null);
    setText(formStatus, message);
  }

  function readProductForm(imageUrl: string | null) {
    if (!productForm) return null;
    const data = new FormData(productForm);
    const slug = slugify(String(data.get('slug') ?? data.get('name') ?? ''));
    const sizes = csv(data.get('sizes'));
    const colors = csv(data.get('colors'));

    if (!slug || !sizes.length || !colors.length) {
      setText(formStatus, 'Add a name, slug, at least one size, and at least one colour.');
      return null;
    }

    return {
      slug,
      name: String(data.get('name') ?? '').trim(),
      category: String(data.get('category')) as CategorySlug,
      price: Number(data.get('price') ?? 0),
      sizes,
      colors,
      summary: String(data.get('summary') ?? '').trim(),
      description: String(data.get('description') ?? '').trim(),
      tag: String(data.get('tag') ?? '').trim() || null,
      featured: data.get('featured') === 'on',
      sort_order: Number(data.get('sort_order') ?? 99),
      image_url: imageUrl,
      published: data.get('published') === 'on',
    };
  }

  function beginEdit(product: RuntimeProduct) {
    if (!productForm) return;
    field<HTMLInputElement>('name')!.value = product.name;
    field<HTMLInputElement>('slug')!.value = product.slug;
    field<HTMLSelectElement>('category')!.value = product.category;
    field<HTMLInputElement>('price')!.value = String(product.price);
    field<HTMLInputElement>('sizes')!.value = product.sizes.join(', ');
    field<HTMLInputElement>('colors')!.value = product.colors.join(', ');
    field<HTMLInputElement>('tag')!.value = product.tag ?? '';
    field<HTMLInputElement>('sort_order')!.value = String(product.sort_order);
    field<HTMLInputElement>('summary')!.value = product.summary;
    field<HTMLTextAreaElement>('description')!.value = product.description;
    setChecked('featured', product.featured);
    setChecked('published', product.published);
    slugWasEdited = true;
    setFormMode(product);
    productForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function loadPreviewProducts(): Array<{ name: string; slug: string; category: string; price: number }> {
    const raw = localStorage.getItem(previewKey);
    if (!raw) return [];
    try {
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function savePreviewProduct(product: { name: string; slug: string; category: string; price: number }) {
    const products = [product, ...loadPreviewProducts()].slice(0, 8);
    localStorage.setItem(previewKey, JSON.stringify(products));
    renderPreviewProducts();
  }

  function renderPreviewProducts() {
    if (!previewList || !previewProducts || hasSupabaseConfig()) return;
    const products = loadPreviewProducts();
    previewList.toggleAttribute('hidden', products.length === 0);
    previewProducts.replaceChildren(
      ...products.map((product) => {
        const item = document.createElement('li');
        const strong = document.createElement('strong');
        strong.textContent = product.name;
        const meta = document.createElement('span');
        meta.textContent = `${product.slug} · ${product.category} · R${product.price}`;
        item.append(strong, meta);
        return item;
      }),
    );
  }

  function renderPreviewProductsTable() {
    if (!productsTable || !productsPanel) return;
    const products = loadPreviewProducts();
    productsPanel.toggleAttribute('hidden', false);
    setText(productsStatus, products.length ? `${products.length} local preview product${products.length === 1 ? '' : 's'}.` : 'No local preview products yet.');
    productsTable.replaceChildren(
      ...products.map((product) => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td><strong></strong></td>
          <td class="admin__slug"></td>
          <td></td>
          <td></td>
          <td><span class="admin__pill">No</span></td>
          <td><span class="admin__pill">Preview</span></td>
          <td>-</td>
          <td><span class="admin__pill">Local only</span></td>
        `;
        row.querySelector('strong')!.textContent = product.name;
        row.children[1].textContent = product.slug;
        row.children[2].textContent = product.category;
        row.children[3].textContent = `R${product.price}`;
        return row;
      }),
    );
  }

  function renderProductsTable(products: RuntimeProduct[]) {
    if (!productsTable) return;
    adminProducts = products;
    productsTable.replaceChildren(
      ...products.map((product) => {
        const row = document.createElement('tr');
        row.dataset.slug = product.slug;
        row.innerHTML = `
          <td><strong></strong></td>
          <td class="admin__slug"></td>
          <td></td>
          <td></td>
          <td><span class="admin__pill"></span></td>
          <td><span class="admin__pill"></span></td>
          <td></td>
          <td>
            <div class="admin__row-actions">
              <a class="admin__action" data-view-product>View</a>
              <button class="admin__action admin__action--edit" type="button" data-edit-product>Edit</button>
              <button class="admin__action admin__action--danger" type="button" data-delete-product>Delete</button>
            </div>
          </td>
        `;
        row.querySelector('strong')!.textContent = product.name;
        row.children[1].textContent = product.slug;
        row.children[2].textContent = categoryLabel(product.category);
        row.children[3].textContent = formatPrice(product.price);
        row.children[4].querySelector('span')!.textContent = product.featured ? 'Yes' : 'No';
        row.children[5].querySelector('span')!.textContent = product.published ? 'Yes' : 'No';
        row.children[6].textContent = String(product.sort_order);
        const view = row.querySelector<HTMLAnchorElement>('[data-view-product]');
        if (view) {
          view.href = productUrl(product.slug);
          view.toggleAttribute('hidden', !product.published);
        }
        return row;
      }),
    );
  }

  async function loadProductsTable() {
    if (!session || !hasSupabaseConfig()) {
      renderPreviewProductsTable();
      return;
    }

    setText(productsStatus, 'Loading products...');
    try {
      const products = await listAdminProducts(session.access_token);
      renderProductsTable(products);
      setText(productsStatus, `${products.length} product${products.length === 1 ? '' : 's'} loaded.`);
    } catch (error) {
      setText(productsStatus, error instanceof Error ? error.message : 'Unable to load products.');
    }
  }

  nameInput?.addEventListener('input', () => {
    if (!slugWasEdited && slugInput) slugInput.value = slugify(nameInput.value);
  });

  slugInput?.addEventListener('input', () => {
    slugWasEdited = true;
    slugInput.value = slugify(slugInput.value);
  });

  loginForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(loginForm);
    const email = String(data.get('email') ?? '');
    const password = String(data.get('password') ?? '');
    setText(globalStatus, 'Signing in...');

    try {
      const result = await signInWithPassword(email, password);
      saveSession(result);
      loginForm.reset();
      setText(globalStatus, '');
    } catch (error) {
      setText(globalStatus, error instanceof Error ? error.message : 'Unable to sign in.');
    }
  });

  signOut?.addEventListener('click', () => {
    saveSession(null);
    setText(globalStatus, 'Signed out.');
  });

  productForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const data = new FormData(productForm);
    const slug = slugify(String(data.get('slug') ?? data.get('name') ?? ''));
    const file = data.get('image');
    const fallbackImage = editingProduct?.image_url ?? null;
    const draftProduct = readProductForm(fallbackImage);
    if (!draftProduct) return;

    if (!hasSupabaseConfig()) {
      savePreviewProduct({
        slug,
        name: draftProduct.name,
        category: draftProduct.category,
        price: draftProduct.price,
      });
      resetProductForm('Preview product saved locally. Connect Supabase to publish live.');
      renderPreviewProductsTable();
      return;
    }

    if (!session) {
      setText(formStatus, 'Sign in before publishing products live.');
      return;
    }

    setText(formStatus, editingProduct ? 'Saving changes...' : 'Creating product...');

    try {
      let imageUrl = fallbackImage;
      if (file instanceof File && file.size > 0) {
        setText(formStatus, 'Uploading image...');
        imageUrl = await uploadProductImage(file, slug, session.access_token);
      }

      const productPayload = { ...draftProduct, image_url: imageUrl || null };
      if (editingProduct) {
        await updateProduct(editingProduct.slug, productPayload, session.access_token);
      } else {
        await createProduct(productPayload, session.access_token);
      }

      const successMessage = editingProduct
        ? 'Product updated.'
        : 'Product created. It can appear on the shop page immediately.';
      resetProductForm(successMessage);
      await loadProductsTable();
    } catch (error) {
      setText(formStatus, error instanceof Error ? error.message : 'Unable to save product.');
    }
  });

  refreshProducts?.addEventListener('click', () => {
    void loadProductsTable();
  });

  cancelEdit?.addEventListener('click', () => {
    resetProductForm('Edit cancelled.');
  });

  productsTable?.addEventListener('click', async (event) => {
    const target = event.target as HTMLElement;
    const row = target.closest<HTMLTableRowElement>('tr[data-slug]');
    if (!row?.dataset.slug) return;
    const product = adminProducts.find((item) => item.slug === row.dataset.slug);
    if (!product) return;

    if (target.closest('[data-edit-product]')) {
      beginEdit(product);
      return;
    }

    if (target.closest('[data-delete-product]')) {
      if (!session) {
        setText(productsStatus, 'Sign in before deleting products.');
        return;
      }
      const confirmed = window.confirm(`Delete "${product.name}"? This cannot be undone.`);
      if (!confirmed) return;

      setText(productsStatus, `Deleting ${product.name}...`);
      try {
        await deleteProduct(product.slug, session.access_token);
        if (editingProduct?.slug === product.slug) resetProductForm('Deleted product.');
        await loadProductsTable();
      } catch (error) {
        setText(productsStatus, error instanceof Error ? error.message : 'Unable to delete product.');
      }
    }
  });

  renderAuthState();
</script>
